# ─── SIGIPLAN · variables de PRODUCCIÓN ──────────────────────────────────────
# Copia este archivo a .env y rellena con valores REALES y seguros.
#   cp .env.prod.example .env
# El archivo .env está en .gitignore: nunca se versiona.

# Entorno (selecciona ProductionConfig)
FLASK_ENV=prod

# Cookies de sesión solo por HTTPS. Déjalo en 'false' MIENTRAS accedas por IP/HTTP
# plano (sin dominio). Cuando quede tras HTTPS/Cloudflare, ponlo en 'true'.
SECURE_COOKIES=false

# Clave de sesión de Flask — OBLIGATORIA en prod.
# Genera una con:  openssl rand -hex 32
SECRET_KEY=CAMBIA_ESTO_por_una_clave_larga_y_aleatoria

# ─── MongoDB (contenedor interno, sin exponer al exterior) ───────────────────
MONGODB_DB=sigiplan
# Credenciales del root de Mongo. Usa una contraseña fuerte:  openssl rand -hex 24
MONGO_USER=sigiplan_root
MONGO_PASSWORD=CAMBIA_ESTO_password_fuerte_de_mongo

# ─── Bootstrap del primer SUPER_ADMIN ────────────────────────────────────────
# Se usa una sola vez con scripts/create_superadmin.py para crear el acceso
# inicial sin datos de demo. Cambia la contraseña tras el primer login.
BOOTSTRAP_ADMIN_EMAIL=admin@goventia.cl
BOOTSTRAP_ADMIN_PASSWORD=CAMBIA_ESTO_password_inicial_admin
BOOTSTRAP_ADMIN_FIRST_NAME=Administrador
BOOTSTRAP_ADMIN_LAST_NAME=Goventia
